{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Android Application Installer",
  "version": "1.6.7",
  "identifier": "com.yahushadmonte.android-application-installer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Android Application Installer",
        "width": 1280,
        "height": 720,
        "minWidth": 1080,
        "minHeight": 520,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://raw.githubusercontent.com/havokentity/android-application-installer/main/updater.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJCOTNBNjRGMzcwRDZCQkUKUldTK2F3MDNUNmFUdThIYWMzeGVDTlBRVmxNaVNTTHVuM29LeVRKTVEvRE5qMUVlYnNmMTRacUMK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
